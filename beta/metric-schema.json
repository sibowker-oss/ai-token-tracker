{
  "meta": {
    "version": "2.1",
    "description": "Field definitions per role. Supports dynamic field discovery \u2014 new fields proposed by Claude are added to proposed_fields until approved.",
    "lastUpdated": "2026-04-02"
  },
  "proposed_fields": [
    {
      "field_id": "vscode_extension_daily_installs",
      "label": "VS Code Extension Daily Installs",
      "unit": "count",
      "type": "primary",
      "yearly": false,
      "description": "Daily active installs of Claude Code extension for VS Code",
      "regex_pattern": "(?:claude code|claude.*extension).*(?:\\d+[MK])\\s*daily.*(?:installs|users|downloads|active)",
      "status": "proposed",
      "proposed_from_claim": "email-20260328-i9r",
      "proposed_for_entity": "anthropic"
    },
    {
      "field_id": "cogs_to_revenue_ratio",
      "label": "Cost of Goods Sold to Revenue Ratio",
      "unit": "ratio",
      "type": "primary",
      "yearly": true,
      "description": "Ratio of spending/costs required to generate $1 in revenue, typically calculated as inference compute costs divided by revenue.",
      "regex_pattern": "(?:spending|cost|cogs)\\s+ratio|\\$[\\d.]+-\\$[\\d.]+\\s+(?:to|per)\\s+\\$?1\\s+(?:in\\s+)?revenue",
      "status": "proposed",
      "proposed_from_claim": "zitron-20260328-e5",
      "proposed_for_entity": "openai"
    },
    {
      "field_id": "revenue_forecast",
      "label": "Revenue Forecast",
      "unit": "$B",
      "type": "primary",
      "yearly": true,
      "description": "Projected annual revenue for a future fiscal year based on internal forecasts or guidance.",
      "regex_pattern": "(?:internal|forecast|projection|guidance)\\s+(?:\\d{4}\\s+)?revenue\\s+(?:forecast|projection|guidance|target).*\\$\\d+[BM]",
      "status": "proposed",
      "proposed_from_claim": "scan-20260330-d4e",
      "proposed_for_entity": "openai"
    },
    {
      "field_id": "burn_rate_pct_of_revenue",
      "label": "Burn Rate (% of Revenue)",
      "unit": "%",
      "type": "primary",
      "yearly": true,
      "description": "Annual cash burn expressed as a percentage of annual revenue, indicating efficiency and runway sustainability.",
      "regex_pattern": "burn\\s+rate\\s+.*?\\d+%\\s+of\\s+revenue|burn.*?\\d+%.*?revenue",
      "status": "proposed",
      "proposed_from_claim": "scan-20260331-c3d",
      "proposed_for_entity": "openai"
    },
    {
      "field_id": "cash_breakeven_timeline",
      "label": "Cash Breakeven Timeline (Years)",
      "unit": "years",
      "type": "primary",
      "yearly": false,
      "description": "Projected number of years until the company reaches cash flow breakeven.",
      "regex_pattern": "(?:cash\\s+flow\\s+)?breakeven\\s+(?:timeline|projection|target|delayed|pushed|expected).*(?:\\d{4}|\\d+\\s+years?)",
      "status": "proposed",
      "proposed_from_claim": "scan-20260331-e5f",
      "proposed_for_entity": "anthropic"
    },
    {
      "field_id": "cloud_backlog",
      "label": "Cloud Backlog",
      "unit": "$B",
      "type": "primary",
      "yearly": false,
      "description": "Future revenue committed through cloud service contracts and agreements",
      "regex_pattern": "(?:cloud|services)\\s+backlog|committed\\s+(?:cloud|services)\\s+revenue|backlog.*cloud",
      "status": "proposed",
      "proposed_from_claim": "scan-20260401-e5f",
      "proposed_for_entity": "google"
    },
    {
      "field_id": "api_pricing",
      "label": "API Pricing Schedule",
      "unit": "string",
      "type": "primary",
      "yearly": false,
      "description": "Current pricing for API access by model and token type, including any surcharges or discounts.",
      "regex_pattern": "(?:API|token|model)\\s+(?:price|pricing|repriced|cost).*(?:per|\\$).*(?:input|output|tokens)",
      "status": "proposed",
      "proposed_from_claim": "scan-20260401-f6g",
      "proposed_for_entity": "anthropic"
    }
  ],
