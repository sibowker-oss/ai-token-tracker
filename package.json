{
  "name": "apac-ai-intel",
  "private": true,
  "version": "0.1.0",
  "description": "The AI Ledger — ai-index.hepburnadvisory.com.au. Static site published via GitHub Pages. This package.json exists to wire the §11 release-check suite (Playwright + provenance validator). The site itself has no build step.",
  "type": "module",
  "scripts": {
    "build": "echo '(static site — no build step)'",
    "preview": "http-server -p 4173 -c-1 --silent .",
    "release-check": "node scripts/release-check.mjs",
    "release-check:provenance": "node scripts/validate-provenance.mjs",
    "release-check:mobile": "playwright test --project mobile-iphone --project mobile-android",
    "release-check:visual": "playwright test tests/release-check/visual.spec.ts",
    "release-check:update-baselines": "playwright test tests/release-check/visual.spec.ts --update-snapshots",
    "build-lint": "node scripts/validate-provenance.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "http-server": "^14.1.1",
    "wait-on": "^8.0.1"
  }
}
