  "meta": {
    "version": "2.2",
    "description": "Field definitions per role + structured claim types. Supports dynamic field discovery \u2014 new fields proposed by Claude are added to proposed_fields until approved. claim_types (v2.2) defines structured payloads emitted by Stream 2 / Stream 3 extractors per wq-014.",
    "lastUpdated": "2026-04-23"
  },
  "proposed_fields": [
    {
      "field_id": "vscode_extension_daily_installs",
      "label": "VS Code Extension Daily Installs",
      "unit": "count",
      "type": "primary",
      "yearly": false,
      "description": "Daily active installs of Claude Code extension for VS Code",
      "regex_pattern": "(?:claude code|claude.*extension).*(?:\\d+[MK])\\s*daily.*(?:installs|users|downloads|active)",
      "status": "proposed",
      "proposed_from_claim": "email-20260328-i9r",
      "proposed_for_entity": "anthropic"
    },
    {
      "field_id": "cogs_to_revenue_ratio",
      "label": "Cost of Goods Sold to Revenue Ratio",
      "unit": "ratio",
      "type": "primary",
      "yearly": true,
      "description": "Ratio of spending/costs required to generate $1 in revenue, typically calculated as inference compute costs divided by revenue.",
      "regex_pattern": "(?:spending|cost|cogs)\\s+ratio|\\$[\\d.]+-\\$[\\d.]+\\s+(?:to|per)\\s+\\$?1\\s+(?:in\\s+)?revenue",
      "status": "proposed",
      "proposed_from_claim": "zitron-20260328-e5",
      "proposed_for_entity": "openai"
    },
    {
      "field_id": "revenue_forecast",
      "label": "Revenue Forecast",
      "unit": "$B",
      "type": "primary",
      "yearly": true,
      "description": "Projected annual revenue for a future fiscal year based on internal forecasts or guidance.",
      "regex_pattern": "(?:internal|forecast|projection|guidance)\\s+(?:\\d{4}\\s+)?revenue\\s+(?:forecast|projection|guidance|target).*\\$\\d+[BM]",
      "status": "proposed",
      "proposed_from_claim": "scan-20260330-d4e",
      "proposed_for_entity": "openai"
    },
    {
      "field_id": "burn_rate_pct_of_revenue",
      "label": "Burn Rate (% of Revenue)",
      "unit": "%",
      "type": "primary",
      "yearly": true,
      "description": "Annual cash burn expressed as a percentage of annual revenue, indicating efficiency and runway sustainability.",
      "regex_pattern": "burn\\s+rate\\s+.*?\\d+%\\s+of\\s+revenue|burn.*?\\d+%.*?revenue",
      "status": "proposed",
      "proposed_from_claim": "scan-20260331-c3d",
      "proposed_for_entity": "openai"
    },
    {
      "field_id": "cash_breakeven_timeline",
      "label": "Cash Breakeven Timeline (Years)",
      "unit": "years",
      "type": "primary",
      "yearly": false,
      "description": "Projected number of years until the company reaches cash flow breakeven.",
      "regex_pattern": "(?:cash\\s+flow\\s+)?breakeven\\s+(?:timeline|projection|target|delayed|pushed|expected).*(?:\\d{4}|\\d+\\s+years?)",
      "status": "proposed",
      "proposed_from_claim": "scan-20260331-e5f",
      "proposed_for_entity": "anthropic"
    },
    {
      "field_id": "cloud_backlog",
      "label": "Cloud Backlog",
      "unit": "$B",
      "type": "primary",
      "yearly": false,
      "description": "Future revenue committed through cloud service contracts and agreements",
      "regex_pattern": "(?:cloud|services)\\s+backlog|committed\\s+(?:cloud|services)\\s+revenue|backlog.*cloud",
      "status": "proposed",
      "proposed_from_claim": "scan-20260401-e5f",
      "proposed_for_entity": "google"
    },
    {
      "field_id": "api_pricing",
      "label": "API Pricing Schedule",
      "unit": "string",
      "type": "primary",
      "yearly": false,
      "description": "Current pricing for API access by model and token type, including any surcharges or discounts.",
      "regex_pattern": "(?:API|token|model)\\s+(?:price|pricing|repriced|cost).*(?:per|\\$).*(?:input|output|tokens)",
      "status": "proposed",
      "proposed_from_claim": "scan-20260401-f6g",
      "proposed_for_entity": "anthropic"
    }
  ],
  "inbox_statuses": {
    "_description": "Valid status values for items in vault-inbox.json. Source of truth for review.html, scripts/apply_claims.py, scripts/auto_clear_inbox.py, and scripts/migrate_orphan_accepts.py. Added under wq-023 (briefs/active/2026-04-25-raw-pool-status.md).",
    "values": ["pending", "accepted", "declined", "parked", "raw_pool"],
    "definitions": {
      "pending": "Awaiting human review in admin.html#review.",
      "accepted": "Reviewed and trusted; updates a live data point in site-data.json. Must have a mapped metric (metricKey) post-wq-023.",
      "raw_pool": "Reviewed and trusted, but no mapped metric — filed for later, not surfaced on the site.",
      "declined": "Reviewed and rejected.",
      "parked": "Held for triangulation or future review."
    }
  },
  "page_lifecycle_statuses": {
    "_description": "Valid status values for entries in data/page-registry.json. Source of truth for scripts/validate_page_registry.py, scripts/build-lint.js (dataReferences gating), and archive.html (Concepts/Retired/Parked sections). Added under wq-031 (briefs/active/2026-04-26-page-lifecycle-registry.md).",
    "values": ["live", "admin", "concept", "beta", "parked", "retired", "newsletter"],
    "definitions": {
      "live": "Public ledger / infrastructure page. In nav. Linted (full dataReferences) unless the entry carries lintExclusions.",
      "admin": "Tooling page (review queue, source admin, settings, etc.). Not in public nav. Schema-checked but skipped on dataReferences.",
      "concept": "Experiment / in-flight idea kept in repo root for active iteration. Not in nav. Excluded from dataReferences. Surfaced on archive.html under the Concepts section.",
      "beta": "Parallel staging tree under /beta/. Not in nav. Excluded by directory boundary on every site-wide check.",
      "parked": "Paused work under /parked/. Not in nav. Excluded from audits. Surfaced on archive.html under the Parked section.",
      "retired": "Superseded by a live page. Frozen content under /archive/. Surfaced on archive.html under the Retired section.",
      "newsletter": "Immutable timestamped artefact under /newsletters/. Not in nav. Excluded from audits."
    },
    "folder_rules": {
      "live": {"required_folder": "<root>", "in_public_nav": true, "linted": true},
      "admin": {"required_folder": "<root> or data-updates/", "in_public_nav": false, "linted": false},
      "concept": {"required_folder": "<root>", "in_public_nav": false, "linted": false},
      "beta": {"required_folder": "beta/", "in_public_nav": false, "linted": false},
      "parked": {"required_folder": "parked/", "in_public_nav": false, "linted": false},
      "retired": {"required_folder": "archive/", "in_public_nav": false, "linted": false, "transition_flag": "pendingMove allows status=retired with path at <root> until the P2 git mv lands"},
      "newsletter": {"required_folder": "newsletters/", "in_public_nav": false, "linted": false}
    },
    "entry_required_fields": ["path", "status", "title", "purpose", "supersedes", "supersededBy", "addedOn", "retiredOn"],
    "entry_optional_fields": ["lastReviewed", "retiredReason", "lintExclusions", "pendingMove", "pendingMoveTo", "_provenance", "_lintExclusionsReason"],
    "retired_required_fields": ["supersededBy", "retiredOn", "retiredReason"]
  },
